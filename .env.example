# ========================================
# Supabase 設定（必須）
# Supabase Dashboard > Settings > API から取得
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# サイト設定
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# 本番サイトURL（og:image・sitemap.xml の絶対URL生成に使用）
NEXT_PUBLIC_SITE_URL=https://kasama-chonaikai.vercel.app

# お問い合わせフォームの送信データは Supabase の contact_submissions テーブルに保存されます
# Supabase の設定（上記）が完了していれば追加設定不要

# ========================================
# 公開前パスワード保護（任意 - 本番公開後は不要）
# ========================================
# SITE_PASSWORD=your-site-password

# ========================================
# 開発環境
# ========================================
NODE_ENV=development
